{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "mesa_ontology",
  "title": "MESA Municipal Ontology",
  "description": "Shared vocabulary for sovereign municipal nodes.",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "author": "Paul Statchen - Santa Cruz, CA",
  "domains": {
    "ITSM": { "description": "IT Service Management", "standard": "ITIL 4" },
    "ESM": { "description": "Enterprise Service Management", "standard": "ITIL 4 extended" },
    "ENERGY_UTILITIES": { "description": "Energy and utilities management", "standard": "NIST" }
  },
  "categories": {
    "ITSM": {
      "incident": { "label": "Incident", "glpi_type": 1 },
      "service_request": { "label": "Service Request", "glpi_type": 2 }
    },
    "ESM": {
      "facilities": { "label": "Facilities", "glpi_type": 1 },
      "hr_services": { "label": "Human Resources", "glpi_type": 2 }
    },
    "ENERGY_UTILITIES": {
      "power_grid": { "label": "Power Grid", "glpi_type": 1, "units": ["kWh", "MW"] },
      "compute_energy": { "label": "Compute Energy", "glpi_type": 2, "units": ["kWh", "watts"] }
    }
  },
  "priority_levels": {
    "critical": { "glpi_urgency": 5 },
    "high": { "glpi_urgency": 4 },
    "medium": { "glpi_urgency": 3 },
    "low": { "glpi_urgency": 1 }
  }
}
